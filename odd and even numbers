#include <iostream>
using namespace std;

int countEvenNumbers(int arr[], int size) {
    int count = 0;
    for (int i = 0; i < size; i++) {
        if (arr[i] % 2 == 0) {
            count++;
        }
    }
    return count;
}

int countOddNumbers(int arr[], int size) {
    int count = 0;
    for (int i = 0; i < size; i++) {
        if (arr[i] % 2 != 0) {
            count++;
        }
    }
    return count;
}

int main() {
    int arraySize;
    cout << "Enter Size of Array: ";
    cin >> arraySize;

    int numbers[arraySize];
    for (int i = 0; i < arraySize; i++) {
        cout << "Enter value in index " << i << ": ";
        cin >> numbers[i];
    }

    int evenCount = countEvenNumbers(numbers, arraySize);
    int oddCount = countOddNumbers(numbers, arraySize);

    cout << "Number of Even Numbers in Array: " << evenCount << endl;
    cout << "Number of Odd Numbers in Array: " << oddCount << endl;

    return 0;
}
