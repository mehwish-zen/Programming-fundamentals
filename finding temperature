#include <iostream>
#include <iomanip>
using namespace std;

double celsiusToFahrenheit(double celsiusTemperature) {
    return (celsiusTemperature * 9 / 5) + 32;
}

int main() {
    double celsiusTemperature;
    cin >> celsiusTemperature;

    double fahrenheitTemperature = celsiusToFahrenheit(celsiusTemperature);

    cout << fixed << setprecision(1) << fahrenheitTemperature << endl;

    return 0;
}
